# ── Canal de Kick ─────────────────────────────────────────────────────────────
CHANNEL_NAME=seniordai

# ── OAuth 2.0 (kick.com/settings/developer → tu app) ─────────────────────────
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# ── Tokens OAuth (generados automáticamente por: cd login && node login.js) ───
KICK_ACCESS_TOKEN=
KICK_REFRESH_TOKEN=
KICK_TOKEN_EXPIRES=0

# ── Credenciales alternativas (fallback si no usas OAuth) ─────────────────────
KICK_USERNAME=
KICK_PASSWORD=
COOKIES=
BEARER_TOKEN=
XSRF_TOKEN=

# ── Panel de control ──────────────────────────────────────────────────────────
# Token para proteger el panel. Cámbialo por algo seguro.
# En nube: configúralo como variable de entorno en Railway/Render/Fly.io
PANEL_TOKEN=cambia_esto_por_un_token_seguro

# ── Respuestas de comandos del chat ──────────────────────────────────────────
# Deja vacío cualquier campo para desactivar ese comando
CMD_DISCORD=https://discord.gg/tu-link
CMD_REDES=Twitch: twitch.tv/seniordai | YouTube: youtube.com/@seniordai | TikTok: @seniordai
CMD_PC=CPU: Ryzen 5 5600X | GPU: RTX 3060 | RAM: 16GB DDR4 | Monitor: 1080p 144Hz
CMD_HORARIO=Lunes, Miércoles y Viernes · 8pm - 12am (hora Lima)

# ── Meta de seguidores ────────────────────────────────────────────────────────
FOLLOW_GOAL=100
CURRENT_FOLLOWERS=0

# ── Pusher (host del cluster correcto — buscar en DevTools > Network > WS de kick.com)
# Ejemplos: ws-mt1.pusher.com  ws-us2.pusher.com  ws-us3.pusher.com  ws-eu.pusher.com
PUSHER_HOST=ws-us2.pusher.com

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
QUEUE_FILE=./data/queue.json
